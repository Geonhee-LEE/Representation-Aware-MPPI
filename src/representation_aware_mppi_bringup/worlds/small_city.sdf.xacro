    <!-- ============================================================== -->
    <!-- Five scripted pedestrians. Coordinates picked from the upstream  -->
    <!-- road/sidewalk grid: roads run y=0,-45,+45 (E-W) and x=-45,-15,   -->
    <!-- 45,110,120 (N-S). Sidewalks line the inside of every block.     -->
    <!--                                                                  -->
    <!--   ped_red    : crosswalk N->S across road_x_2 (y=0) at x=-30     -->
    <!--   ped_blue   : sidewalk patrol along the +Y side of road_x_2     -->
    <!--                from (-38,3) to (-22,3)                           -->
    <!--   ped_green  : plaza wandering near apartment_76 (~87, -21)      -->
    <!--   ped_white  : long pedestrian street walk eastbound on the      -->
    <!--                +Y sidewalk of road_x_2 from x=-15 to x=110       -->
    <!--   ped_red2   : diagonal crossing between buildings at (-30,-25)  -->
    <!--                                                                  -->
    <!-- Speeds tuned to ~1.0 m/s to match the walk DAE animation rate.   -->
    <!-- Yaw at each waypoint points toward the next so the actor faces   -->
    <!-- forward. Z=1.0 places the actor's pelvis on the road/sidewalk.   -->
    <!-- ============================================================== -->

    <!-- 1. Crosswalk crossing: north-south across road_x_2 (y=0) at x=-30 -->
    <xacro:walking_actor name="ped_red" skin_dae="walk-red.dae" init_x="-30.0" init_y="6.0">
      <script>
        <loop>true</loop>
        <delay_start>0.0</delay_start>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walk">
          <waypoint><time>0</time>    <pose>-30.0  6.0 1.0 0 0 -1.5708</pose></waypoint>
          <waypoint><time>12</time>   <pose>-30.0 -6.0 1.0 0 0 -1.5708</pose></waypoint>
          <waypoint><time>12.4</time> <pose>-30.0 -6.0 1.0 0 0  1.5708</pose></waypoint>
          <waypoint><time>24</time>   <pose>-30.0  6.0 1.0 0 0  1.5708</pose></waypoint>
        </trajectory>
      </script>
    </xacro:walking_actor>

    <!-- 2. Sidewalk patrol: east-west on the +Y sidewalk of road_x_2 -->
    <xacro:walking_actor name="ped_blue" skin_dae="walk-blue.dae" init_x="-38.0" init_y="5.5">
      <script>
        <loop>true</loop>
        <delay_start>1.0</delay_start>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walk">
          <waypoint><time>0</time>    <pose>-38.0  5.5 1.0 0 0  0.0</pose></waypoint>
          <waypoint><time>16</time>   <pose>-22.0  5.5 1.0 0 0  0.0</pose></waypoint>
          <waypoint><time>16.4</time> <pose>-22.0  5.5 1.0 0 0  3.14159</pose></waypoint>
          <waypoint><time>32</time>   <pose>-38.0  5.5 1.0 0 0  3.14159</pose></waypoint>
        </trajectory>
      </script>
    </xacro:walking_actor>

    <!-- 3. Plaza wandering: small loop in the open area south of apartment_76 -->
    <xacro:walking_actor name="ped_green" skin_dae="walk-green.dae" init_x="80.0" init_y="-30.0">
      <script>
        <loop>true</loop>
        <delay_start>0.5</delay_start>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walk">
          <waypoint><time>0</time>    <pose>80.0 -30.0 1.0 0 0  0.0</pose></waypoint>
          <waypoint><time>6</time>    <pose>86.0 -30.0 1.0 0 0  1.5708</pose></waypoint>
          <waypoint><time>12</time>   <pose>86.0 -24.0 1.0 0 0  3.14159</pose></waypoint>
          <waypoint><time>18</time>   <pose>80.0 -24.0 1.0 0 0 -1.5708</pose></waypoint>
          <waypoint><time>24</time>   <pose>80.0 -30.0 1.0 0 0  0.0</pose></waypoint>
        </trajectory>
      </script>
    </xacro:walking_actor>

    <!-- 4. Long pedestrian street walk: eastbound on +Y sidewalk of road_x_2 -->
    <xacro:walking_actor name="ped_white" skin_dae="walk.dae" init_x="-15.0" init_y="6.0">
      <script>
        <loop>true</loop>
        <delay_start>2.0</delay_start>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walk">
          <waypoint><time>0</time>     <pose>-15.0  6.0 1.0 0 0  0.0</pose></waypoint>
          <waypoint><time>125</time>   <pose>110.0  6.0 1.0 0 0  0.0</pose></waypoint>
          <waypoint><time>125.4</time> <pose>110.0  6.0 1.0 0 0  3.14159</pose></waypoint>
          <waypoint><time>250</time>   <pose>-15.0  6.0 1.0 0 0  3.14159</pose></waypoint>
        </trajectory>
      </script>
    </xacro:walking_actor>

    <!-- 5. Diagonal crossing between buildings near (-30, -25) -->
    <xacro:walking_actor name="ped_red2" skin_dae="walk-red.dae" init_x="-35.0" init_y="-20.0">
      <script>
        <loop>true</loop>
        <delay_start>0.0</delay_start>
