<?xml version="1.0"?>
<!--
  small_city.sdf.xacro - Gazebo Harmonic port of RDSim's small_city.world
  (rdsim_gazebo/worlds/small_city.world, BSD-3-Clause; Service Robotics Lab,
  Universidad Pablo de Olavide). Copyright headers preserved per BSD-3-Clause.

  Stage 2 of the RDSim port: a much larger outdoor environment than the
  Stage 1 cafe shell. ~170 m x 100 m, road grid plus apartments, gas
  station, ambulance, hatchback cars, oak/pine trees, lamp posts, fire
  hydrants, fast food, fountain, etc. The full include list (185 entries)
  is preserved verbatim from upstream below.

  Differences vs. upstream small_city.world:
    * Removed the Gazebo Classic plugin <plugin filename="libgazebo_ros_state.so">
      (replaced by the Harmonic stack below).
    * Removed the upstream actor1 block, which used the SFM plugin
      (libPedestrianSFMPlugin.so) - reactive social-force pedestrians are
      Stage 3 work. Five scripted <actor>s are appended below to provide
      visual pedestrian content (sidewalk patrol, crosswalk, plaza
      wandering, long pedestrian street, diagonal between buildings).
    * <scene>'s upstream <sky><clouds> block is preserved as-is: Harmonic
      tolerates the tag (renders a default sky if the engine ignores it)
      and removing it loses upstream parity for no benefit.
    * Ground plane <mu>100</mu><mu2>50</mu2> is preserved verbatim - this
      is the same explicit-mu2 fix we applied for the outdoor TB3, just
      already present upstream here.
    * Physics step 0.005 s preserved; if Harmonic has trouble with the
      large city scene at this step, downgrade in caller's launch via a
      future xacro arg.
    * <include> URIs use model:// scheme - they resolve at runtime via
      GZ_SIM_RESOURCE_PATH which the launch file sets to point at the
      external clone of RDSim's models tree (~1.3 GB; not committed).
      Fetch with scripts/fetch_rdsim_models.sh.

  Args:
    * headless (default true): if true, omit SceneBroadcaster.
    * meshes_path: absolute path to the package's meshes dir; the launch
      resolves it via get_package_share_directory so the rendered SDF
      carries absolute file:// URIs for the actor skin DAEs.
-->
<sdf version="1.6" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="headless" default="true"/>
  <xacro:arg name="meshes_path" default="package://representation_aware_mppi_bringup/meshes"/>
  <xacro:property name="meshes" value="$(arg meshes_path)"/>

  <!-- Reusable scripted actor macro (matches cafe3_jazzy.sdf.xacro). -->
  <xacro:macro name="walking_actor"
               params="name skin_dae init_x init_y *script_body">
    <actor name="${name}">
      <pose>${init_x} ${init_y} 1.0 0 0 0</pose>
      <skin>
        <filename>${meshes}/actors/${skin_dae}</filename>
        <scale>1.0</scale>
      </skin>
      <animation name="walk">
        <filename>${meshes}/actors/${skin_dae}</filename>
        <scale>1.0</scale>
        <interpolate_x>true</interpolate_x>
      </animation>
      <xacro:insert_block name="script_body"/>
    </actor>
  </xacro:macro>

  <world name="default">
    <plugin
      filename="gz-sim-physics-system"
      name="gz::sim::systems::Physics">
    </plugin>
    <plugin
      filename="gz-sim-user-commands-system"
      name="gz::sim::systems::UserCommands">
    </plugin>
  <xacro:unless value="$(arg headless)">
    <plugin
      filename="gz-sim-scene-broadcaster-system"
      name="gz::sim::systems::SceneBroadcaster">
    </plugin>
  </xacro:unless>
    <plugin
      filename="gz-sim-sensors-system"
      name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin
      filename="gz-sim-imu-system"
      name="gz::sim::systems::Imu">
    </plugin>

    <!-- GUI camera: upstream view, looking from south-west toward the city. -->
    <gui fullscreen="0">
      <camera name="user_camera">
        <pose>-40.637 0.86 2.365 0 0.1899 0.476</pose>
      </camera>
    </gui>

    <scene>
      <grid>false</grid>
      <origin_visual>false</origin_visual>
      <ambient>0.85 0.85 0.85 1</ambient>
      <sky>
        <clouds>
          <speed>12</speed>
        </clouds>
      </sky>
      <background>0.35 0.35 0.35 1.0</background>
    </scene>

    <physics name='default_physics' default='0' type='ode'>
      <max_step_size>0.005</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>200</real_time_update_rate>
    </physics>

    <!-- A global light source -->
    <light type="directional" name="sun">
      <pose>0 0 1000 0 0 0</pose>
      <cast_shadows>true</cast_shadows>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.4</direction>
    </light>

    <!-- ground plane (upstream mu=100/mu2=50 preserved) -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>100</mu>
                <mu2>50</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
      </link>
    </model>

    <!-- ============================================================== -->
    <!-- Upstream city body (185 includes + 9 roads + 40 sidewalk/asphalt -->
    <!-- /gas_station models). Verbatim from RDSim small_city.world,     -->
    <!-- BSD-3-Clause. Pedestrian SFM actor1 is intentionally excluded;  -->
    <!-- five scripted actors are appended after this block.             -->
    <!-- ============================================================== -->
    <include>
      <name>city_terrain_1</name>
      <pose>
      0
      0
      0.0
      0
      0
      0
      </pose>
      <uri>model://city_terrain</uri>
    </include>

    <include>
      <name>ocean_2</name>
      <pose>
      40
      -20
      -2
      0
      0
      0
      </pose>
      <uri>model://ocean</uri>
    </include>




    <road name="road_y_1">
      <width>7.4</width>
      <point>-45 -48.7 0.01</point>
      <point>-45 49.2 0.01</point>



    </road>


    <road name="road_y_2">
      <width>7.4</width>
      <point>-15 -48.7 0.01</point>
      <point>-15 49.2 0.01</point>


      <material>
        <script>
          <uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Residential</name>
        </script>
      </material>


    </road>


    <road name="road_y_3">
      <width>7.4</width>
      <point>45 -48.7 0.01</point>
      <point>45 49.2 0.01</point>


      <material>
        <script>
          <uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Residential</name>
        </script>
      </material>


    </road>


    <road name="road_y_4">
      <width>7.4</width>
      <point>110 -48.7 0.01</point>
      <point>110 49.2 0.01</point>


      <material>
        <script>
          <uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Residential</name>
        </script>
      </material>


    </road>


    <road name="road_y_5">
      <width>7.4</width>
      <point>120 -48.7 0.01</point>
      <point>120 49.2 0.01</point>



    </road>


    <road name="road_x_1">

      <width>8.4</width>
      <point>-41.3 -45 0.015</point>
      <point>116.3 -45 0.015</point>



    </road>


    <road name="road_x_2">

      <width>8.4</width>
      <point>-41.3 0 0.015</point>
      <point>116.3 0 0.015</point>


      <material>
        <script>
          <uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Residential</name>
        </script>
      </material>


    </road>


    <road name="road_x_3">

      <width>8.4</width>
      <point>-41.3 45 0.015</point>
      <point>116.3 45 0.015</point>



    </road>



