<?xml version="1.0"?>
<!--
  Phase 0 + dynamic obstacles variant of nav2_minimal_tb3_sim/tb3_sandbox.sdf.xacro.
  Upstream content is preserved verbatim (sun, ground, scene, physics, sensor/imu/physics
  plugins, turtlebot3_world include). Five capsule pedestrians are appended as plain
  <model>+TrajectoryFollower so they remain visible to gpu_lidar (collision geometry
  participates in ray casts; <actor> meshes do not without extra collision links).
-->
<sdf version="1.6" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="headless" default="true"/>

  <!-- Reusable pedestrian macro: plain <model> with capsule visual+collision and
       a TrajectoryFollower plugin. Speed is governed by <force> vs mass+damping;
       70 kg with force=80 reaches ~1 m/s steady state on the ground plane.        -->
  <xacro:macro name="pedestrian"
               params="name x y r g b force:=80 torque:=40 range_tol:=0.3 bearing_tol:=0.2 *waypoints">
    <model name="${name}">
      <pose>${x} ${y} 0.85 0 0 0</pose>
      <self_collide>false</self_collide>
      <link name="link">
        <inertial>
          <mass>70.0</mass>
          <inertia>
            <ixx>5.0</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>5.0</iyy>
            <iyz>0</iyz>
            <izz>1.0</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <capsule>
              <radius>0.25</radius>
              <length>1.2</length>
            </capsule>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>0.5</mu>
                <mu2>0.5</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <capsule>
              <radius>0.25</radius>
              <length>1.2</length>
            </capsule>
          </geometry>
          <material>
            <ambient>${r} ${g} ${b} 1</ambient>
            <diffuse>${r} ${g} ${b} 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
          </material>
        </visual>
      </link>

      <plugin filename="gz-sim-trajectory-follower-system"
              name="gz::sim::systems::TrajectoryFollower">
        <link_name>link</link_name>
        <loop>true</loop>
        <force>${force}</force>
        <torque>${torque}</torque>
        <range_tolerance>${range_tol}</range_tolerance>
        <bearing_tolerance>${bearing_tol}</bearing_tolerance>
        <waypoints>
          <xacro:insert_block name="waypoints"/>
        </waypoints>
      </plugin>
    </model>
  </xacro:macro>

  <world name="default">
    <plugin
      filename="gz-sim-physics-system"
      name="gz::sim::systems::Physics">
    </plugin>
    <plugin
      filename="gz-sim-user-commands-system"
      name="gz::sim::systems::UserCommands">
    </plugin>
  <xacro:unless value="$(arg headless)">
    <plugin
      filename="gz-sim-scene-broadcaster-system"
      name="gz::sim::systems::SceneBroadcaster">
    </plugin>
  </xacro:unless>
    <plugin
      filename="gz-sim-sensors-system"
      name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin
      filename="gz-sim-imu-system"
      name="gz::sim::systems::Imu">
    </plugin>

    <light name='sun' type='directional'>
        <cast_shadows>0</cast_shadows>
        <pose>0 0 10 0 0 0</pose>
        <diffuse>0.8 0.8 0.8 1</diffuse>
        <specular>0.8 0.8 0.8 1</specular>
        <attenuation>
            <range>1000</range>
            <constant>0.9</constant>
            <linear>0.01</linear>
            <quadratic>0.001</quadratic>
        </attenuation>
        <direction>-0.5 0.1 -0.9</direction>
    </light>
    <model name='ground_plane'>
        <static>1</static>
        <link name='link'>
            <collision name='collision'>
                <geometry>
                    <plane>
                        <normal>0 0 1</normal>
                        <size>100 100</size>
                    </plane>
                </geometry>
                <max_contacts>10</max_contacts>
            </collision>
            <visual name='visual'>
                <geometry>
                    <plane>
                        <normal>0 0 1</normal>
                        <size>100 100</size>
                    </plane>
                </geometry>
                <material>
                    <ambient>0.8 0.8 0.8 1</ambient>
                    <diffuse>0.8 0.8 0.8 1</diffuse>
                    <specular>0.8 0.8 0.8 1</specular>
                </material>
            </visual>
        </link>
    </model>

    <scene>
      <shadows>0</shadows>
    </scene>

    <physics name='3ms' type='ode'>
        <max_step_size>0.003</max_step_size>
        <real_time_factor>1</real_time_factor>
    </physics>

    <model name="turtlebot3_world">
      <static>1</static>
      <include>
        <uri>model://turtlebot3_world</uri>
      </include>
    </model>

    <!--
      Five pedestrians. Waypoints stay in the open corridor strip outside the
      turtlebot3_world cylinder ring (which sits roughly inside |x|,|y| < 1.2)
      and away from the TB3 spawn at (-2.0, -0.5). Speeds are tuned via <force>:
      higher force at fixed mass (70 kg) yields a higher steady-state cruise.
    -->

    <!-- 1) Red: east-west crossing in the lower corridor. ~1.2 m/s. -->
    <xacro:pedestrian name="ped_red" x="2.0" y="-1.7" r="0.9" g="0.1" b="0.1"
                      force="100" torque="50">
      <waypoints>
        <waypoint>2.0 -1.7</waypoint>
        <waypoint>-2.0 -1.7</waypoint>
      </waypoints>
    </xacro:pedestrian>

    <!-- 2) Blue: circular patrol on r=1.7 around origin (4 corners). ~0.8 m/s. -->
    <xacro:pedestrian name="ped_blue" x="1.7" y="0.0" r="0.1" g="0.2" b="0.9"
                      force="60" torque="40">
      <waypoints>
        <waypoint>1.7 0.0</waypoint>
        <waypoint>0.0 1.7</waypoint>
        <waypoint>-1.7 0.0</waypoint>
        <waypoint>0.0 -1.7</waypoint>
      </waypoints>
    </xacro:pedestrian>

    <!-- 3) Green: north-south oscillation along the east edge. ~1.4 m/s. -->
    <xacro:pedestrian name="ped_green" x="2.2" y="-2.0" r="0.1" g="0.8" b="0.2"
                      force="120" torque="55">
      <waypoints>
        <waypoint>2.2 -2.0</waypoint>
        <waypoint>2.2 2.0</waypoint>
      </waypoints>
    </xacro:pedestrian>

    <!-- 4) Yellow: slow figure-8 (4 waypoints). ~0.6 m/s. -->
    <xacro:pedestrian name="ped_yellow" x="-2.2" y="1.5" r="0.95" g="0.85" b="0.1"
                      force="40" torque="30">
      <waypoints>
        <waypoint>-2.2 1.5</waypoint>
        <waypoint>-1.5 2.2</waypoint>
        <waypoint>-2.2 2.5</waypoint>
        <waypoint>-2.5 1.8</waypoint>
      </waypoints>
    </xacro:pedestrian>

    <!-- 5) Magenta: diagonal cross through the south-east open quadrant. ~1.0 m/s. -->
    <xacro:pedestrian name="ped_magenta" x="-1.8" y="-2.2" r="0.9" g="0.1" b="0.8"
                      force="80" torque="45">
      <waypoints>
        <waypoint>-1.8 -2.2</waypoint>
        <waypoint>2.2 1.8</waypoint>
      </waypoints>
    </xacro:pedestrian>

  </world>
</sdf>
