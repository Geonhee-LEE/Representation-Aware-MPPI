<?xml version="1.0"?>
<!--
  Phase 0 + dynamic obstacles variant of nav2_minimal_tb3_sim/tb3_sandbox.sdf.xacro.
  Step B v2 — Gazebo <actor> with skeletal walking animation (Fuel walk.dae,
  auto-downloaded on first run) and scripted <trajectory> waypoints. Smooth
  time-interpolated motion (no force/PD jitter), proper human appearance.

  Actors do not have physics collision, so they are NOT visible to gpu_lidar
  (/scan, /points). They ARE visible to the RGB camera (/rgb_camera/image)
  which is the primary signal for the upcoming P1 (BEV semantic seg) work.
  Reactive social-force pedestrians (PedSim/HuNav) are deferred to P4.

  RViz pose sync: ros_gz_bridge bridges /world/default/dynamic_pose/info
  (gz.msgs.Pose_V) to ROS /tf so each actor appears as a TF frame. See
  configs/extra_sensors_bridge.yaml.
-->
<sdf version="1.6" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="headless" default="true"/>

  <!-- Reusable actor macro. Uses Fuel-hosted walk.dae (downloaded once,
       cached at ~/.gz/fuel). The script trajectory dictates ground speed
       by waypoint time deltas; tune waypoint times so distance/dt matches
       the natural walk animation rate (~1 m/s) for a non-glitchy look.    -->
  <xacro:macro name="walking_actor"
               params="name init_x init_y *script_body">
    <actor name="${name}">
      <pose>${init_x} ${init_y} 1.0 0 0 0</pose>
      <skin>
        <filename>https://fuel.gazebosim.org/1.0/Mingfei/models/actor/tip/files/meshes/walk.dae</filename>
        <scale>1.0</scale>
      </skin>
      <animation name="walk">
        <filename>https://fuel.gazebosim.org/1.0/Mingfei/models/actor/tip/files/meshes/walk.dae</filename>
        <interpolate_x>true</interpolate_x>
      </animation>
      <xacro:insert_block name="script_body"/>
    </actor>
  </xacro:macro>

  <world name="default">
    <plugin
      filename="gz-sim-physics-system"
      name="gz::sim::systems::Physics">
    </plugin>
    <plugin
      filename="gz-sim-user-commands-system"
      name="gz::sim::systems::UserCommands">
    </plugin>
  <xacro:unless value="$(arg headless)">
    <plugin
      filename="gz-sim-scene-broadcaster-system"
      name="gz::sim::systems::SceneBroadcaster">
    </plugin>
  </xacro:unless>
    <plugin
      filename="gz-sim-sensors-system"
      name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin
      filename="gz-sim-imu-system"
      name="gz::sim::systems::Imu">
    </plugin>

    <light name='sun' type='directional'>
        <cast_shadows>0</cast_shadows>
        <pose>0 0 10 0 0 0</pose>
        <diffuse>0.8 0.8 0.8 1</diffuse>
        <specular>0.8 0.8 0.8 1</specular>
        <attenuation>
            <range>1000</range>
            <constant>0.9</constant>
            <linear>0.01</linear>
            <quadratic>0.001</quadratic>
        </attenuation>
        <direction>-0.5 0.1 -0.9</direction>
    </light>
    <model name='ground_plane'>
        <static>1</static>
        <link name='link'>
            <collision name='collision'>
                <geometry>
                    <plane>
                        <normal>0 0 1</normal>
                        <size>100 100</size>
                    </plane>
                </geometry>
                <max_contacts>10</max_contacts>
            </collision>
            <visual name='visual'>
                <geometry>
                    <plane>
                        <normal>0 0 1</normal>
                        <size>100 100</size>
                    </plane>
                </geometry>
                <material>
                    <ambient>0.8 0.8 0.8 1</ambient>
                    <diffuse>0.8 0.8 0.8 1</diffuse>
                    <specular>0.8 0.8 0.8 1</specular>
                </material>
            </visual>
        </link>
    </model>

    <scene>
      <shadows>0</shadows>
    </scene>

    <physics name='3ms' type='ode'>
        <max_step_size>0.003</max_step_size>
        <real_time_factor>1</real_time_factor>
    </physics>

    <model name="turtlebot3_world">
      <static>1</static>
      <include>
        <uri>model://turtlebot3_world</uri>
      </include>
    </model>

    <!--
      Pedestrians. Waypoint times are tuned so distance/dt ≈ walk animation
      ground speed (~1 m/s) for a natural gait. Yaw at each waypoint points
      toward the next so the actor faces its direction of travel.
    -->

    <!-- 1. East ↔ West along south corridor (~1.0 m/s, 4 m one-way) -->
    <xacro:walking_actor name="ped_red" init_x="2.0" init_y="-1.7">
      <script>
        <loop>true</loop>
        <delay_start>0.0</delay_start>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walk">
          <waypoint><time>0</time><pose>2.0 -1.7 1.0 0 0 3.14159</pose></waypoint>
          <waypoint><time>4</time><pose>-2.0 -1.7 1.0 0 0 3.14159</pose></waypoint>
          <waypoint><time>4.2</time><pose>-2.0 -1.7 1.0 0 0 0</pose></waypoint>
          <waypoint><time>8.2</time><pose>2.0 -1.7 1.0 0 0 0</pose></waypoint>
        </trajectory>
      </script>
    </xacro:walking_actor>

    <!-- 2. Square patrol around origin r ≈ 1.7 m (~1.0 m/s, 2.4 m sides → 2.4 s each) -->
    <xacro:walking_actor name="ped_blue" init_x="1.7" init_y="0.0">
      <script>
        <loop>true</loop>
        <delay_start>0.0</delay_start>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walk">
          <waypoint><time>0</time>   <pose>1.7  0.0 1.0 0 0 1.5708</pose></waypoint>
          <waypoint><time>2.4</time> <pose>0.0  1.7 1.0 0 0 3.14159</pose></waypoint>
          <waypoint><time>4.8</time> <pose>-1.7 0.0 1.0 0 0 -1.5708</pose></waypoint>
          <waypoint><time>7.2</time> <pose>0.0 -1.7 1.0 0 0 0</pose></waypoint>
          <waypoint><time>9.6</time> <pose>1.7  0.0 1.0 0 0 1.5708</pose></waypoint>
        </trajectory>
      </script>
    </xacro:walking_actor>

    <!-- 3. North ↔ South east edge (~1.3 m/s, 4 m one-way → 3 s) -->
    <xacro:walking_actor name="ped_green" init_x="2.2" init_y="-2.0">
      <script>
        <loop>true</loop>
        <delay_start>1.0</delay_start>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walk">
          <waypoint><time>0</time>   <pose>2.2 -2.0 1.0 0 0 1.5708</pose></waypoint>
          <waypoint><time>3</time>   <pose>2.2  2.0 1.0 0 0 1.5708</pose></waypoint>
          <waypoint><time>3.2</time> <pose>2.2  2.0 1.0 0 0 -1.5708</pose></waypoint>
          <waypoint><time>6.2</time> <pose>2.2 -2.0 1.0 0 0 -1.5708</pose></waypoint>
        </trajectory>
      </script>
    </xacro:walking_actor>

    <!-- 4. Slow figure-8 ish in NW corner (~0.6 m/s) -->
    <xacro:walking_actor name="ped_yellow" init_x="-2.2" init_y="1.8">
      <script>
        <loop>true</loop>
        <delay_start>0.0</delay_start>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walk">
          <waypoint><time>0</time>   <pose>-2.2 1.8 1.0 0 0 0</pose></waypoint>
          <waypoint><time>1.5</time> <pose>-1.5 2.2 1.0 0 0 0.7854</pose></waypoint>
          <waypoint><time>3.0</time> <pose>-2.2 1.8 1.0 0 0 3.14159</pose></waypoint>
          <waypoint><time>4.5</time> <pose>-2.9 1.4 1.0 0 0 -2.3562</pose></waypoint>
          <waypoint><time>6.0</time> <pose>-2.2 1.8 1.0 0 0 0</pose></waypoint>
        </trajectory>
      </script>
    </xacro:walking_actor>

    <!-- 5. Diagonal SW ↔ NE (~1.0 m/s, 5.7 m one-way → 5.7 s) -->
    <xacro:walking_actor name="ped_magenta" init_x="-1.8" init_y="-2.2">
      <script>
        <loop>true</loop>
        <delay_start>2.0</delay_start>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walk">
          <waypoint><time>0</time>    <pose>-1.8 -2.2 1.0 0 0 0.7854</pose></waypoint>
          <waypoint><time>5.7</time>  <pose>2.2 1.8 1.0 0 0 0.7854</pose></waypoint>
          <waypoint><time>5.9</time>  <pose>2.2 1.8 1.0 0 0 -2.3562</pose></waypoint>
          <waypoint><time>11.6</time> <pose>-1.8 -2.2 1.0 0 0 -2.3562</pose></waypoint>
        </trajectory>
      </script>
    </xacro:walking_actor>

  </world>
</sdf>
